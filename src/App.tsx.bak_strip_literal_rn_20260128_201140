          baseUrl: provider.ollamaBaseUrl,
          model: provider.ollamaModel,
          messages: history,
          signal: controller.signal,
          onToken,
        });
      }
    } catch (e: any) {
      const msg = e?.name === "AbortError" ? "[stopped]" : `[error] ${e?.message || String(e)}`;
      setChats((prev) => {
        const next = prev.map((c) => {
          if (c.id !== chat.id) return c;
          const newMsgs = c.messages.map((m, idx) =>
            idx === asstIdx ? { ...m, content: (m.content || "") + `\n\n${msg}` } : m
          );
          return { ...c, updatedAt: Date.now(), messages: newMsgs };
        });
        saveChats(next);
        return next;
      });
    } finally {
      abortRef.current = null;
      setIsStreaming(false);
    }
  };
const send = async (text: string) => {
