use futures_util::StreamExt;
use once_cell::sync::OnceCell;
use reqwest::Client;
use serde::Serialize;
use serde_json::Value;
use std::collections::HashMap;
use std::sync::Mutex;
use tauri::Window;
use tokio_util::sync::CancellationToken;

const EVT_TOKEN: &str = "ollama://token";
const EVT_DONE: &str = "ollama://done";
const EVT_ERROR: &str = "ollama://error";

#[derive(Serialize, Clone)]
struct TokenPayload {
  id: String,
  token: String,
}

#[derive(Serialize, Clone)]
struct DonePayload {
  id: String,
  aborted: bool,
}

#[derive(Serialize, Clone)]
struct ErrorPayload {
  id: String,
  error: String,
}

static JOBS: OnceCell<Mutex<HashMap<String, CancellationToken>>> = OnceCell::new();

fn jobs() -> &'static Mutex<HashMap<String, CancellationToken>> {
  JOBS.get_or_init(|| Mutex::new(HashMap::new()))
}

fn normalize_base_url(s: &str) -> String {
  let t = s.trim().trim_end_matches('/').to_string();
  if t.starts_with("http://") || t.starts_with("https://") {
    t
  } else {
    format!("http://{}", t)
  }
}

fn client() -> Client {
  Client::new()
}

#[tauri::command]
pub async fn ollama_tags(base_url: String) -> Result<Value, String> {
  let base = normalize_base_url(&base_url);
  let url = format!("{}/api/tags", base);

  let resp = client().get(url).send().await.map_err(|e| e.to_string())?;
  let status = resp.status();

  if !status.is_success() {
    let text = resp.text().await.unwrap_or_else(|_| "".to_string());
    return Err(format!("ollama /api/tags failed ({}): {}", status, text));
  }

  resp.json::<Value>().await.map_err(|e| e.to_string())
}

#[tauri::command]
pub async fn ollama_chat_once(base_url: String, body: Value) -> Result<Value, String> {
  let base = normalize_base_url(&base_url);
  let url = format!("{}/api/chat", base);

  let resp = client()
    .post(url)
    .json(&body)
    .send()
    .await
    .map_err(|e| e.to_string())?;

  let status = resp.status();
  if !status.is_success() {
    let text = resp.text().await.unwrap_or_else(|_| "".to_string());
    return Err(format!("ollama /api/chat failed ({}): {}", status, text));
  }

  resp.json::<Value>().await.map_err(|e| e.to_string())
}

#[tauri::command]
pub async fn ollama_chat_abort(id: String) -> Result<(), String> {
  if let Some(tok) = jobs().lock().unwrap().remove(&id) {
    tok.cancel();
  }
  Ok(())
}

#[tauri::command]
pub async fn ollama_chat_stream(window: Window, id: String, base_url: String, body: Value) -> Result<(), String> {
  let base = normalize_base_url(&base_url);
  let url = format!("{}/api/chat", base);

  // Create cancel token and register it
  let cancel = CancellationToken::new();
  jobs().lock().unwrap().insert(id.clone(), cancel.clone());

  let window2 = window.clone();
  tokio::spawn(async move {
    let do_emit_done = |aborted: bool| {
      let _ = window2.emit(EVT_DONE, DonePayload { id: id.clone(), aborted });
    };
    let do_emit_err = |msg: String| {
      let _ = window2.emit(EVT_ERROR, ErrorPayload { id: id.clone(), error: msg });
    };
    let do_emit_tok = |t: String| {
      let _ = window2.emit(EVT_TOKEN, TokenPayload { id: id.clone(), token: t });
    };

    let resp = match client().post(url).json(&body).send().await {
      Ok(r) => r,
      Err(e) => {
        do_emit_err(format!("request failed: {}", e));
        do_emit_done(false);
        jobs().lock().unwrap().remove(&id);
        return;
      }
    };

    let status = resp.status();
    if !status.is_success() {
      let text = resp.text().await.unwrap_or_else(|_| "".to_string());
      do_emit_err(format!("ollama error ({}): {}", status, text));
      do_emit_done(false);
      jobs().lock().unwrap().remove(&id);
      return;
    }

    let mut stream = resp.bytes_stream();
    let mut buf: Vec<u8> = Vec::new();
    let mut aborted = false;

    loop {
      let next = tokio::select! {
        _ = cancel.cancelled() => {
          aborted = true;
          None
        }
        n = stream.next() => n
      };

      match next {
        None => break,
        Some(Err(e)) => {
          do_emit_err(format!("stream read failed: {}", e));
          break;
        }
        Some(Ok(chunk)) => {
          buf.extend_from_slice(&chunk);

          // Process NDJSON lines
          while let Some(pos) = buf.iter().position(|&b| b == b'\n') {
            let line_bytes: Vec<u8> = buf.drain(..=pos).collect();
            let line = String::from_utf8_lossy(&line_bytes);
            let line = line.trim();
            if line.is_empty() {
              continue;
            }

            let v: Value = match serde_json::from_str(line) {
              Ok(x) => x,
              Err(_) => continue,
            };

            // Extract token from either /message/content (chat) or /response (generate)
            if let Some(t) = v.pointer("/message/content").and_then(|x| x.as_str()) {
              if !t.is_empty() {
                do_emit_tok(t.to_string());
              }
            } else if let Some(t) = v.get("response").and_then(|x| x.as_str()) {
              if !t.is_empty() {
                do_emit_tok(t.to_string());
              }
            }

            // If ollama includes an error field
            if let Some(err) = v.get("error").and_then(|x| x.as_str()) {
              do_emit_err(err.to_string());
            }

            let done = v.get("done").and_then(|x| x.as_bool()).unwrap_or(false);
            if done {
              do_emit_done(aborted);
              jobs().lock().unwrap().remove(&id);
              return;
            }
          }
        }
      }
    }

    do_emit_done(aborted);
    jobs().lock().unwrap().remove(&id);
  });

  Ok(())
}
