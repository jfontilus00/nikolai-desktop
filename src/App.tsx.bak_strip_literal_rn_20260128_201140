    // push user + empty assistant
    const updatedChats = chats.map((c) =>
      c.id === chat!.id ? { ...c, updatedAt: Date.now(), messages: [...c.messages, userMsg, assistantMsg] } : c
    );
    persist(updatedChats);

    // TOOL PATH
    const trimmed = text.trim();
    if (trimmed.toLowerCase() === "/tools") {
      try {
        const tools = await mcpListTools();

        appendToolLog({
          id: `tl-${Date.now()}`,
          ts: Date.now(),
          tool: "mcp_list_tools",
          args: {},
          ok: true,
          result: tools,
        });

        const lines = (tools || []).map((t: any) => {
          const desc = t?.description ? ` — ${t.description}` : "";
          return `- ${t.name}${desc}`;
        });

        const msg =
          lines.length > 0
            ? `Available tools (${lines.length}):\n` + lines.join("\n")
            : "No tools available. Open the Tools tab and click “List tools” (and ensure MCP is connected).";

        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat!.id) return c;
            const msgs = c.messages.map((m) => (m.id === assistantMsgId ? { ...m, content: msg } : m));
            return { ...c, updatedAt: Date.now(), messages: msgs };
          });
          saveChats(next);
          return next;
        });
      } catch (e: any) {
        appendToolLog({
          id: `tl-${Date.now()}`,
          ts: Date.now(),
          tool: "mcp_list_tools",
          args: {},
          ok: false,
          error: e?.message || String(e),
        });

        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat!.id) return c;
            const msgs = c.messages.map((m) =>
              m.id === assistantMsgId ? { ...m, content: `[tool error] ${e?.message || String(e)}` } : m
            );
            return { ...c, updatedAt: Date.now(), messages: msgs };
          });
          saveChats(next);
          return next;
        });
      }
      return;
    }
        // /read <path>  -> fs.read_file
    if (trimmed.toLowerCase().startsWith("/read ")) {
      const path = trimmed.slice(6).trim();
      try {
        if (!path) throw new Error("Usage: /read C:/path/to/file");

        const out = await mcpCallTool("fs.read_file", { path });
        appendToolLog({ id: `tl-${Date.now()}`, ts: Date.now(), tool: "fs.read_file", args: { path }, ok: true, result: out });

        const formatted = formatToolResult("fs.read_file", out);
        if (formatted.isError) throw new Error(formatted.text || "Tool returned error");

        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat!.id) return c;
            const msgs = c.messages.map((m) => (m.id === assistantMsgId ? { ...m, content: formatted.text } : m));
            return { ...c, updatedAt: Date.now(), messages: msgs };
          });
          saveChats(next);
          return next;
        });
      } catch (e: any) {
        appendToolLog({ id: `tl-${Date.now()}`, ts: Date.now(), tool: "fs.read_file", args: { path }, ok: false, error: e?.message || String(e) });
        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat!.id) return c;
            const msgs = c.messages.map((m) => (m.id === assistantMsgId ? { ...m, content: `[tool error] ${e?.message || String(e)}` } : m));
            return { ...c, updatedAt: Date.now(), messages: msgs };
          });
          saveChats(next);
          return next;
        });
      }
      return;
    }

    // /grep <pattern> <dir> -> fs.search_files
    if (trimmed.toLowerCase().startsWith("/grep ")) {
      const rest = trimmed.slice(6).trim();
      try {
        if (!rest) throw new Error("Usage: /grep <pattern> <dir>. Example: /grep TODO C:/Dev/Nikolai-desktop");

        // split into: pattern + dir (dir is last token)
        const parts = rest.split(" ").map((x) => x.trim()).filter(Boolean);
        if (parts.length < 2) throw new Error("Usage: /grep <pattern> <dir>");

        const dir = parts[parts.length - 1];
        const pattern = parts.slice(0, parts.length - 1).join(" ");

                const base = dir.replace(/\/+$/, "");
        const isCodeFolder = /\/src(?:-tauri)?$/i.test(base);

        const targets = isCodeFolder ? [base] : [`${base}/src`, `${base}/src-tauri`];

        let allMatches: any[] = [];
        for (const p of targets) {
          try {
            const r = await mcpCallTool("fs.search_files", { path: p, query: pattern });
            // Collect common shapes: {matches: [...] } or { success:true, matches:[...] }
            const m = (r && (r.matches || (r.success ? r.matches : null))) || [];
            if (Array.isArray(m)) allMatches = allMatches.concat(m);
          } catch {
            // ignore per-target failures
          }
        }

        const out = { success: true, matches: allMatches, total: allMatches.length, searched: targets };appendToolLog({ id: `tl-${Date.now()}`, ts: Date.now(), tool: "fs.search_files", args: { path: dir, query: pattern }, ok: true, result: out });

        const formatted = formatToolResult("fs.search_files", out);
        if (formatted.isError) throw new Error(formatted.text || "Tool returned error");

        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat!.id) return c;
            const msgs = c.messages.map((m) => (m.id === assistantMsgId ? { ...m, content: formatted.text } : m));
            return { ...c, updatedAt: Date.now(), messages: msgs };
          });
          saveChats(next);
          return next;
        });
      } catch (e: any) {
        appendToolLog({ id: `tl-${Date.now()}`, ts: Date.now(), tool: "fs.search_files", args: { raw: rest }, ok: false, error: e?.message || String(e) });
        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat!.id) return c;
            const msgs = c.messages.map((m) => (m.id === assistantMsgId ? { ...m, content: `[tool error] ${e?.message || String(e)}` } : m));
            return { ...c, updatedAt: Date.now(), messages: msgs };
          });
          saveChats(next);
          return next;
        });
      }
      return;
    }
const toolCmd = parseToolCommand(text);
    if (toolCmd) {
      try {
        if (toolCmd.args?.__parse_error__) {
          throw new Error(toolCmd.args.__parse_error__);
        }

        const out = await mcpCallTool(toolCmd.name, toolCmd.args || {});
        const formatted = formatToolResult(toolCmd.name, out);
        if (formatted.isError) {
          throw new Error(formatted.text || "Tool returned error");
        }
appendToolLog({
          id: `tl-${Date.now()}`,
          ts: Date.now(),
          tool: toolCmd.name,
          args: toolCmd.args || {},
          ok: true,
          result: out,
        });

        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat!.id) return c;
            const msgs = c.messages.map((m) =>
              m.id === assistantMsgId ? { ...m, content: formatted.text } : m
            );
            return { ...c, updatedAt: Date.now(), messages: msgs };
          });
          saveChats(next);
          return next;
        });
      } catch (e: any) {
        appendToolLog({
          id: `tl-${Date.now()}`,
          ts: Date.now(),
          tool: toolCmd.name,
          args: toolCmd.args || {},
          ok: false,
          error: e?.message || String(e),
        });

        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat!.id) return c;
            const msgs = c.messages.map((m) =>
              m.id === assistantMsgId ? { ...m, content: `[tool error] ${e?.message || String(e)}` } : m
            );
            return { ...c, updatedAt: Date.now(), messages: msgs };
          });
          saveChats(next);
          return next;
        });
      }
      return;
    }
    // OLLAMA STREAM PATH
    setIsStreaming(true);
    const controller = new AbortController();
    abortRef.current = controller;

    try {
      const currentChats = loadChats();
      const currentChat = currentChats.find((c) => c.id === chat!.id);

      const history = (currentChat?.messages || [])
        .filter((m) => m.role === "user" || (m.content || "").trim().length > 0)
        .map((m) => ({ role: m.role, content: m.content }));

      const onToken = (t: string) => {
        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat!.id) return c;
            const msgs = c.messages.map((m) =>
              m.id === assistantMsgId ? { ...m, content: (m.content || "") + t } : m
            );
            return { ...c, updatedAt: Date.now(), messages: msgs };
          });
          saveChats(next);
          return next;
        });
      };

      const onStatus = (s: string) => {
        const status = s ? `__STATUS__:${s}` : "";
        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat!.id) return c;
            const msgs = c.messages.map((m) => {
              if (m.id !== assistantMsgId) return m;
              const cur = (m.content || "");
              if (cur && !cur.startsWith("__STATUS__:")) return m;
              return { ...m, content: status };
            });
            return { ...c, updatedAt: Date.now(), messages: msgs };
          });
          return next;
        });
      };

      if (shouldUseAgentic(text)) {
        await agenticStreamChat({
          baseUrl: provider.ollamaBaseUrl,
          model: provider.ollamaModel,
          messages: history as any,
          signal: controller.signal,
          onToken,
          onStatus,
          maxSteps: 3,
          executeTool: executeToolWithApproval,
        
          plannerModel: (provider.ollamaPlannerModel || provider.ollamaModel),
});
      } else {
        await ollamaStreamChat({
          baseUrl: provider.ollamaBaseUrl,
          model: provider.ollamaModel,
          messages: history,
          signal: controller.signal,
          onToken,
        });
      }
    } catch (e: any) {
      const msg = e?.name === "AbortError" ? "[stopped]" : `[error] ${e?.message || String(e)}`;
      setChats((prev) => {
