import { useEffect, useMemo, useState } from "react";
import type { ProviderConfig } from "../types";
import ToolsPanel from "./ToolsPanel";
import { fetchOllamaModels } from "../lib/ollamaModels";

type Props = {
  collapsed: boolean;
  provider: ProviderConfig;
  setProvider: (p: ProviderConfig) => void;
  onInsertToComposer?: (text: string) => void;
};

export default function RightPanel({ collapsed, provider, setProvider, onInsertToComposer }: Props) {
  const [tab, setTab] = useState<"providers" | "tools" | "about">("providers");

  const [models, setModels] = useState<string[]>([]);
  const [modelsLoading, setModelsLoading] = useState(false);
  const [modelsError, setModelsError] = useState<string | null>(null);

  const baseUrl = provider?.ollamaBaseUrl || "";
  const chatModel = provider?.ollamaModel || "";
  const plannerModel = provider?.ollamaPlannerModel || chatModel;

  const refreshModels = async () => {
    setModelsLoading(true);
    setModelsError(null);
    try {
      const list = await fetchOllamaModels(baseUrl);
      setModels(list);
      if (list.length === 0) setModelsError("No models returned by /api/tags");
    } catch (e: any) {
      setModels([]);
      setModelsError(e?.message || String(e));
    } finally {
      setModelsLoading(false);
    }
  };

  useEffect(() => {
    if (tab === "providers" && baseUrl.trim()) refreshModels();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [tab, baseUrl]);

  const modelOptions = useMemo(() => models, [models]);

  if (collapsed) return <div className="h-full w-full" />;

  return (
    <div className="h-full flex flex-col border-l border-white/10">
      <div className="h-12 flex items-center gap-2 px-3 border-b border-white/10">
        <button
          className={`px-3 py-1 rounded ${tab === "providers" ? "bg-white/10" : "bg-transparent"} hover:bg-white/10`}
          onClick={() => setTab("providers")}
        >
          Providers
        </button>
        <button
          className={`px-3 py-1 rounded ${tab === "tools" ? "bg-white/10" : "bg-transparent"} hover:bg-white/10`}
          onClick={() => setTab("tools")}
        >
          Tools
        </button>
        <button
          className={`px-3 py-1 rounded ${tab === "about" ? "bg-white/10" : "bg-transparent"} hover:bg-white/10`}
          onClick={() => setTab("about")}
        >
          About
        </button>
      </div>

      <div className="flex-1 overflow-auto p-3">
        {tab === "providers" && (
          <div className="space-y-3">
            <div className="text-xs font-semibold opacity-80">Active Provider</div>

            <div className="border border-white/10 rounded-lg p-3 bg-white/5 space-y-3">
              <div className="text-xs opacity-70">Ollama (local / LAN)</div>

              <label className="block text-xs opacity-70">Base URL</label>
              <input
                className="w-full rounded-md bg-black/30 border border-white/10 px-3 py-2 text-sm outline-none focus:border-white/30"
                value={baseUrl}
                onChange={(e) => setProvider({ ...provider, ollamaBaseUrl: e.target.value })}
                placeholder="http://127.0.0.1:11434"
              />

              <div className="flex items-center justify-between gap-2">
                <label className="block text-xs opacity-70">Chat model (answers)</label>
                <button
                  className="text-xs px-2 py-1 rounded bg-white/10 hover:bg-white/15 border border-white/10 disabled:opacity-50"
                  onClick={refreshModels}
                  disabled={modelsLoading || !baseUrl.trim()}
                >
                  {modelsLoading ? "Loading…" : "Refresh models"}
                </button>
              </div>

              <select
                className="w-full rounded-md bg-black/30 border border-white/10 px-3 py-2 text-sm outline-none focus:border-white/30"
                value={chatModel}
                onChange={(e) => setProvider({ ...provider, ollamaModel: e.target.value })}
              >
                {modelOptions.length === 0 ? (
                  <option value={chatModel || ""}>{chatModel ? chatModel : "No models loaded"}</option>
                ) : (
                  modelOptions.map((m) => (
                    <option key={m} value={m}>
                      {m}
                    </option>
                  ))
                )}
              </select>

              <div className="text-[11px] opacity-60">Tip: You can type a model manually if it isn't listed.</div>
              <input
                className="w-full rounded-md bg-black/30 border border-white/10 px-3 py-2 text-sm outline-none focus:border-white/30"
                value={chatModel}
                onChange={(e) => setProvider({ ...provider, ollamaModel: e.target.value })}
                placeholder="e.g. qwen2.5:7b-instruct-q4_K_M"
              />

              <div className="border-t border-white/10 pt-3 space-y-2">
                <div className="text-xs font-semibold opacity-80">Planner model (agentic tools)</div>
                <div className="text-xs opacity-70">
                  Used only for tool planning (fast & stable). Final answers still use Chat model.
                </div>

                <select
                  className="w-full rounded-md bg-black/30 border border-white/10 px-3 py-2 text-sm outline-none focus:border-white/30"
                  value={plannerModel}
                  onChange={(e) => setProvider({ ...provider, ollamaPlannerModel: e.target.value })}
                >
                  {modelOptions.length === 0 ? (
                    <option value={plannerModel || ""}>{plannerModel ? plannerModel : "No models loaded"}</option>
                  ) : (
                    modelOptions.map((m) => (
                      <option key={m} value={m}>
                        {m}
                      </option>
                    ))
                  )}
                </select>

                <input
                  className="w-full rounded-md bg-black/30 border border-white/10 px-3 py-2 text-sm outline-none focus:border-white/30"
                  value={plannerModel}
                  onChange={(e) => setProvider({ ...provider, ollamaPlannerModel: e.target.value })}
                  placeholder="e.g. qwen2.5:3b-instruct"
                />
              </div>

              {modelsError ? <div className="text-xs text-amber-300">{modelsError}</div> : null}
            </div>
          </div>
        )}

        {tab === "tools" && <ToolsPanel onInsertToComposer={onInsertToComposer} />}

        {tab === "about" && (
          <div className="space-y-2 text-sm">
            <div className="font-semibold">Nikolai Desktop</div>
            <div className="opacity-70 text-sm">Local assistant with MCP tools + agentic tool approval.</div>
          </div>
        )}
      </div>
    </div>
  );
}

