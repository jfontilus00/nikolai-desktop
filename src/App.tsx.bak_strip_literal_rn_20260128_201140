      if (shouldUseAgentic(prompt)) {
        await agenticStreamChat({
          baseUrl: provider.ollamaBaseUrl,
          model: provider.ollamaModel,
          messages: history as any,
          signal: controller.signal,
          onToken,
          onStatus,
          maxSteps: 3,
