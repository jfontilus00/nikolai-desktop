import { ollamaChat, type OllamaMsg } from "./ollamaChat";
import { ollamaStreamChat } from "./ollamaStream";
import { mcpListTools, type McpTool } from "./mcp";
import { appendToolLog } from "./toolLog";
import { formatToolResult } from "./toolResult";

type Plan =
  | { action: "tool"; name: string; args: any }
  | { action: "final"; content: string };

function stripCodeFences(s: string) {
  return (s || "").trim().replace(/^```(?:json)?/i, "").replace(/```$/i, "").trim();
}

function parsePlan(raw: string): Plan | null {
  const cleaned = stripCodeFences(raw);
  const start = cleaned.indexOf("{");
  const end = cleaned.lastIndexOf("}");
  if (start < 0 || end <= start) return null;
  try {
    const obj: any = JSON.parse(cleaned.slice(start, end + 1));
    if (obj?.action === "tool" && typeof obj?.name === "string") return { action: "tool", name: obj.name, args: obj.args ?? {} };
    if (obj?.action === "final" && typeof obj?.content === "string") return { action: "final", content: obj.content };
    return null;
  } catch {
    return null;
  }
}

function isAllowedAgenticTool(name: string): boolean {
  if (name.startsWith("fs.")) return true;
  if (name.startsWith("project-brain.")) return true;

  const pfx = "doc-suite.doc_suite.";
  if (name.startsWith(pfx)) {
    const rest = name.slice(pfx.length);
    if (rest.startsWith("export_")) return true;
    if (rest.startsWith("render_")) return true;
    if (rest.startsWith("security_")) return true;
    if (rest === "suite_self_test") return true;
    if (rest === "email_draft_eml") return true;
    if (rest === "calendar_invite_ics") return true;
    return false; // block online by default
  }
  return false;
}

function toolCatalog(tools: McpTool[]): string {
  const safe = (tools || []).filter((t) => isAllowedAgenticTool(t.name));
  if (safe.length === 0) return "(no tools available)";
  return safe.map((t) => `- ${t.name}${t.description ? ` — ${t.description}` : ""}`).join("\n");
}

async function runTool(
  toolName: string,
  args: any,
  exec: (name: string, args: any) => Promise<any>,
  onStatus?: (s: string) => void
): Promise<{ ok: boolean; formattedText: string; raw: any }> {
  onStatus?.(`Running: ${toolName}`);

  try {
    const out = await exec(toolName, args ?? {});
    const formatted = formatToolResult(toolName, out);

    appendToolLog({
      id: `tl-${Date.now()}`,
      ts: Date.now(),
      tool: toolName,
      args: args ?? {},
      ok: !formatted.isError,
      result: formatted.isError ? undefined : out,
      error: formatted.isError ? formatted.text : undefined,
    });

    return { ok: !formatted.isError, formattedText: formatted.text, raw: out };
  } finally {
    onStatus?.(""); // clear spinner line
  }
}

export async function agenticStreamChat(opts: {
  baseUrl: string;
  model: string;
  messages: OllamaMsg[];
  signal: AbortSignal;
  onToken: (t: string) => void;
  onStatus?: (s: string) => void;
  maxSteps?: number;
  executeTool?: (name: string, args: any) => Promise<any>;
}): Promise<void> {
  const maxSteps = opts.maxSteps ?? 3;

  // HARD: no silent tool calls
  if (!opts.executeTool) {
    opts.onToken(`\n\n[agent] Approval executor missing (executeTool). Tool calls are blocked.\n`);
    return;
  }

  // Ensure MCP tools available
  let tools: McpTool[] = [];
  try {
    tools = await mcpListTools();
  } catch (e: any) {
    opts.onToken(`\n\n[agent] MCP tools not available (${e?.message || String(e)}). Tools tab → Connect → List tools.\n`);
    return;
  }

  const catalog = toolCatalog(tools);
  if (!catalog) {
    opts.onToken(`\n\n[agent] No allowed tools available.\n`);
    return;
  }

  // Build convo context
  let convo: OllamaMsg[] = [...opts.messages];

  for (let step = 1; step <= maxSteps; step++) {
    if (opts.signal.aborted) throw Object.assign(new Error("Aborted"), { name: "AbortError" });

    const plannerSystem: OllamaMsg = {
      role: "system",
      content:
        `You are a tool planner. ONLY output one JSON object.\n` +
        `Tool: {"action":"tool","name":"<tool>","args":{...}}\n` +
        `Final: {"action":"final","content":"..."}\n\n` +
        `Allowed tools:\n${catalog}\n\n` +
        `Rules:\n- Never invent file lists or code. Use tools.\n- Avoid node_modules.\n`,
    };

    const planText = await ollamaChat({
      baseUrl: opts.baseUrl,
      model: opts.model,
      messages: [plannerSystem, ...convo],
      signal: opts.signal,
    });

    const plan = parsePlan(planText);
    if (!plan || plan.action === "final") break;

    if (!isAllowedAgenticTool(plan.name)) {
      convo.push({ role: "assistant", content: `[tool blocked] ${plan.name}` });
      continue;
    }

    const r = await runTool(plan.name, plan.args ?? {}, opts.executeTool, opts.onStatus);

    if (r.ok) {
      convo.push({ role: "assistant", content: `[tool result] ${plan.name}\n${r.formattedText}` });
    } else {
      convo.push({ role: "assistant", content: `[tool error] ${plan.name}\n${r.formattedText}` });
    }
  }

  const finalSystem: OllamaMsg = {
    role: "system",
    content:
      `Answer using the tool results included in the chat.\n` +
      `Do NOT output JSON tool directives.\n`,
  };

  await ollamaStreamChat({
    baseUrl: opts.baseUrl,
    model: opts.model,
    messages: [finalSystem, ...convo],
    signal: opts.signal,
    onToken: opts.onToken,
  });
}
