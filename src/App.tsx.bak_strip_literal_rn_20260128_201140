import React, { useMemo, useRef, useState } from "react";
import type { ChatThread, Message, ProviderConfig } from "./types";
import { uid } from "./lib/id";
import {
  loadActiveChatId,
  loadChats,
  saveActiveChatId,
  saveChats,
  loadLayout,
  loadProvider,
  saveProvider,
} from "./lib/storage";
import ResizableShell from "./components/ResizableShell";
import ChatHistory from "./components/ChatHistory";
import ChatCenter from "./components/ChatCenter";
import RightPanel from "./components/RightPanel";
import ToolApprovalModal from "./components/ToolApprovalModal";
import ErrorBoundary from "./components/ErrorBoundary";
import { ollamaStreamChat } from "./lib/ollamaStream";
import { agenticStreamChat } from "./lib/agentic";
import { parseToolCommand } from "./lib/toolCmd";
import { mcpCallTool, mcpListTools } from "./lib/mcp";
import { appendToolLog } from "./lib/toolLog";
import { formatToolResult } from "./lib/toolResult";

function shouldUseAgentic(text: string) {
  const t = (text || "").trim().toLowerCase();
  if (!t) return false;
  if (t.startsWith("/")) return false;

  // ALWAYS agentic for MCP/tooling questions
  if (t.includes("mcp") || t.includes("tool") || t.includes("tools")) return true;

  // Tool-ish intents
  return /(read|open|file|folder|dir|directory|list|grep|search|find|project|analy|export|docx|pdf|pptx|xlsx|report|diagram|mermaid)/.test(t);
}
function newChat(): ChatThread {
  const id = uid("chat");
  const now = Date.now();
  return { id, title: "New chat", createdAt: now, updatedAt: now, messages: [] };
}

export default function App() {
  const [chats, setChats] = useState<ChatThread[]>(() => loadChats());
  const [activeId, setActiveId] = useState<string | null>(() => loadActiveChatId());
  const [leftCollapsed, setLeftCollapsed] = useState(() => loadLayout().leftCollapsed);
  const [rightCollapsed, setRightCollapsed] = useState(() => loadLayout().rightCollapsed);

  const [provider, setProviderState] = useState<ProviderConfig>(() => loadProvider());

  const [isStreaming, setIsStreaming] = useState(false);
  const abortRef = useRef<AbortController | null>(null);


  // Tool approval (agentic auto-calls)
  const toolApprovalResolveRef = useRef<((choice: "deny" | "once" | "chat") => void) | null>(null);
  const [toolApproval, setToolApproval] = useState<{ open: boolean; toolName: string; toolArgs: any }>({
    open: false,
    toolName: "",
    toolArgs: {},
  });
  const [toolAllowInChat, setToolAllowInChat] = useState<Record<string, boolean>>({});

  const requestToolApproval = (toolName: string, toolArgs: any) =>
    new Promise<"deny" | "once" | "chat">((resolve) => {
      toolApprovalResolveRef.current = resolve;
      setToolApproval({ open: true, toolName, toolArgs });
    });

  const closeToolApproval = (choice: "deny" | "once" | "chat") => {
    setToolApproval((p) => ({ ...p, open: false }));
    const r = toolApprovalResolveRef.current;
    toolApprovalResolveRef.current = null;
    r?.(choice);
  };


  function normalizeWinPath(p: string) {
    const s = String(p || "").trim().replace(/^"(.*)"$/, "$1");
    // Convert backslashes to forward slashes for fs MCP server
    return s.replace(/\\/g, "/");
  }

  function normalizeFsArgs(tool: string, a: any) {
    const args = (a && typeof a === "object") ? { ...a } : {};
    // common path keys
    for (const k of ["path", "src", "dst", "from", "to"]) {
      if (typeof (args as any)[k] === "string") {
        (args as any)[k] = normalizeWinPath((args as any)[k]);
      }
    }
    return args;
  }

  function validateToolArgs(tool: string, args: any): { ok: true } | { ok: false; error: string } {
    const a = (args && typeof args === "object") ? args : {};

    const need = (k: string) => {
      const v = (a as any)[k];
      return typeof v === "string" && v.trim().length > 0;
    };

    if (tool === "fs.read_file") {
      if (!need("path")) return { ok: false, error: "fs.read_file requires args: { path: \"...\" }" };
    }

    if (tool === "fs.list_directory") {
      if (!need("path")) return { ok: false, error: "fs.list_directory requires args: { path: \"...\" }" };
    }

    if (tool === "fs.search_files") {
      if (!need("path") || !need("query")) return { ok: false, error: "fs.search_files requires args: { path: \"...\", query: \"...\" }" };
    }

    if (tool === "fs.write_file") {
      if (!need("path")) return { ok: false, error: "fs.write_file requires args: { path: \"...\", content: \"...\" }" };
      const content = (a as any).content;
      if (typeof content !== "string") return { ok: false, error: "fs.write_file requires args.content as a string" };
    }

    return { ok: true };
  }
  const executeToolWithApproval = async (name: string, args: any) => {
    // Guardrails: normalize + validate before approval/execution
    const normalizedArgs = normalizeFsArgs(name, args);
    const v = validateToolArgs(name, normalizedArgs);
    if (!v.ok) throw new Error(`Tool args invalid: ${v.error}`);

    // Already allowed for this chat?
    if (toolAllowInChat[`${activeId || "nochat"}::${name}`]) return await mcpCallTool(name, normalizedArgs);

    const choice = await requestToolApproval(name, normalizedArgs);
    if (choice === "deny") throw new Error("Tool denied by user");

    if (choice === "chat") {
      setToolAllowInChat((prev) => ({ ...prev, [`${activeId || "nochat"}::${name}`]: true }));
    }
    // "once" simply proceeds without storing
    return await mcpCallTool(name, normalizedArgs);
  };
  // allows ToolsPanel to insert text into chat composer later (v2)
  const composerInsertRef = useRef<(t: string) => void>(() => {});

  const activeChat = useMemo(() => chats.find((c) => c.id === activeId) || null, [chats, activeId]);

  const persist = (next: ChatThread[], nextActive?: string | null) => {
    setChats(next);
    saveChats(next);
    if (typeof nextActive !== "undefined") {
      setActiveId(nextActive);
      saveActiveChatId(nextActive);
    }
  };

  const setProvider = (p: ProviderConfig) => {
    setProviderState(p);
    saveProvider(p);
  };

  const createChat = () => {
    const c = newChat();
    const next = [c, ...chats];
    persist(next, c.id);
  };

  const deleteChat = (id: string) => {
    const next = chats.filter((c) => c.id !== id);
    const nextActive = activeId === id ? (next[0]?.id ?? null) : activeId;
    persist(next, nextActive);
  };

  const renameChat = (id: string, title: string) => {
    const next = chats.map((c) => (c.id === id ? { ...c, title, updatedAt: Date.now() } : c));
    persist(next);
  };

  const selectChat = (id: string) => {
    setActiveId(id);
    saveActiveChatId(id);
  };

  const stop = () => {
    abortRef.current?.abort();
    abortRef.current = null;
    setIsStreaming(false);
  };

  
  
  const clearStatusForActiveChat = () => {
    const chat = activeChat;
    if (!chat) return;

    setChats((prev) => {
      const next = prev.map((c) => {
        if (c.id !== chat.id) return c;
        const msgs = c.messages.map((m) => {
          if (m.role === "assistant" && typeof m.content === "string" && m.content.startsWith("__STATUS__:")) {
            return { ...m, content: "" };
          }
          return m;
        });
        return { ...c, updatedAt: Date.now(), messages: msgs };
      });
      saveChats(next);
      return next;
    });
  };
const regenerateLast = async () => {
    const chat = activeChat;
    if (!chat) return;
    if (isStreaming) return;

    const msgs = chat.messages || [];
    let userIdx = -1;
    for (let i = msgs.length - 1; i >= 0; i--) {
      if (msgs[i].role === "user") { userIdx = i; break; }
    }
    if (userIdx < 0) return;

    let asstIdx = -1;
    for (let i = msgs.length - 1; i > userIdx; i--) {
      if (msgs[i].role === "assistant") { asstIdx = i; break; }
    }
    if (asstIdx < 0) return;

    const prompt = (msgs[userIdx].content || "").trim();
    if (!prompt || prompt.startsWith("/")) return;

    // Clear last assistant message content
    setChats((prev) => {
      const next = prev.map((c) => {
        if (c.id !== chat.id) return c;
        const newMsgs = c.messages.map((m, idx) => (idx === asstIdx ? { ...m, content: "" } : m));
        return { ...c, updatedAt: Date.now(), messages: newMsgs };
      });
      saveChats(next);
      return next;
    });

    setIsStreaming(true);
    const controller = new AbortController();
    abortRef.current = controller;

    try {
      const baseHistory = msgs
        .slice(0, userIdx + 1)
        .filter((m) => m.role === "user" || (m.content || "").trim().length > 0)
        .map((m) => ({ role: m.role, content: m.content }));

      const history = [{ role: "system", content: NIKOLAI_SYSTEM_PROMPT }, ...baseHistory];

      const onToken = (t: string) => {
        setChats((prev) => {
          const next = prev.map((c) => {
            if (c.id !== chat.id) return c;
            const newMsgs = c.messages.map((m, idx) =>
              idx === asstIdx ? { ...m, content: (m.content || "") + t } : m
            );
            return { ...c, updatedAt: Date.now(), messages: newMsgs };
          });
          saveChats(next);
          return next;
        });
      };

      const onStatus = (s: string) => {
        const status = s ? `__STATUS__:${s}` : "";
