          const next = prev.map((c) => {
            if (c.id !== chat.id) return c;
            const newMsgs = c.messages.map((m, idx) => {
              if (idx !== asstIdx) return m;
              const cur = (m.content || "");
              if (cur && !cur.startsWith("__STATUS__:") && status) return m;
              return { ...m, content: status };
            });
            return { ...c, updatedAt: Date.now(), messages: newMsgs };
          });
          return next;
        });
