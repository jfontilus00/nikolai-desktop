import React, { useEffect, useRef, useState } from "react";
import type { ChatThread, Message } from "../types";

type Props = {
  chat: ChatThread | null;
  onSend: (text: string) => void;
  isStreaming: boolean;
  onStop: () => void;
};

export default function ChatCenter({ chat, onSend, isStreaming, onStop }: Props) {
  const [text, setText] = useState("");
  const endRef = useRef<HTMLDivElement | null>(null);

  useEffect(() => {
    endRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [chat?.messages.length]);

  if (!chat) {
    return (
      <div className="h-full flex items-center justify-center">
        <div className="text-center space-y-2">
          <div className="text-xl font-bold">Nikolai Desktop</div>
          <div className="text-sm opacity-70">Create a chat from the left panel.</div>
        </div>
      </div>
    );
  }

  return (
    <div className="h-full flex flex-col">
      <div className="h-12 flex items-center justify-between px-4 border-b border-white/10">
        <div className="font-semibold">{chat.title}</div>
        <div className="text-xs opacity-70 flex items-center gap-3">
          {isStreaming ? <span className="text-green-300">● streaming</span> : <span>idle</span>}
          <span>Messages: {chat.messages.length}</span>
        </div>
      </div>

      <div className="flex-1 overflow-auto p-4 space-y-3">
        {chat.messages.map((m) => (
          <MessageBubble key={m.id} m={m} />
        ))}
        <div ref={endRef} />
      </div>

      <div className="border-t border-white/10 p-3">
        <div className="flex gap-2">
          <textarea
            value={text}
            onChange={(e) => setText(e.target.value)}
            rows={2}
            placeholder="Type a message…"
            className="flex-1 resize-none rounded-md bg-white/5 border border-white/10 px-3 py-2 text-sm outline-none focus:border-white/30"
            onKeyDown={(e) => {
              if ((e.ctrlKey || e.metaKey) && e.key === "Enter") {
                e.preventDefault();
                const t = text.trim();
                if (!t) return;
                onSend(t);
                setText("");
              }
            }}
            disabled={isStreaming}
          />

          {!isStreaming ? (
            <button
              className="rounded-md bg-blue-600 hover:bg-blue-500 px-4 py-2 text-sm font-semibold disabled:opacity-50"
              onClick={() => {
                const t = text.trim();
                if (!t) return;
                onSend(t);
                setText("");
              }}
              disabled={!text.trim()}
            >
              Send
            </button>
          ) : (
            <button
              className="rounded-md bg-amber-600 hover:bg-amber-500 px-4 py-2 text-sm font-semibold"
              onClick={onStop}
            >
              Stop
            </button>
          )}
        </div>

        <div className="mt-2 text-xs opacity-60">
          Tip: Ctrl+Enter to send {isStreaming ? "• Streaming is running (Stop to cancel)" : ""}
        </div>
      </div>
    </div>
  );
}

function MessageBubble({ m }: { m: Message }) {
  const isUser = m.role === "user";
  return (
    <div className={`flex ${isUser ? "justify-end" : "justify-start"}`}>
      <div
        className={`max-w-[80%] rounded-2xl px-4 py-3 text-sm border ${
          isUser ? "bg-blue-600/20 border-blue-500/30" : "bg-white/5 border-white/10"
        }`}
      >
        <div className="whitespace-pre-wrap leading-relaxed">{m.content}</div>
        <div className="mt-2 text-[10px] opacity-60">{new Date(m.ts).toLocaleTimeString()}</div>
      </div>
    </div>
  );
}
